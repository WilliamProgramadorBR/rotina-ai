{
  "expo": {
    "name": "Rotina AI",
    "slug": "rotina-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rotinaai",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.williamdevbackend.rotinaai",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "SEU_PROJECT_ID_DO_EAS"
      }
    }
  }
}