{
  "expo": {
    "name": "Rotina AI",
    "slug": "rotina-ai",
    "description": "Gerenciador de rotinas inteligente desenvolvido por William Oliveira Dos Santos.",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rotinaai",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.williamdevbackend.rotinaai",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/rotina_alarm.wav"
          ]
        }
      ],
      "expo-font",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": true,
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "creator": {
        "name": "William Oliveira Dos Santos",
        "contact": "william100william@gmail.com",
        "expoOwner": "williamdevbackend"
      },
      "router": {},
      "eas": {
        "projectId": "cc180b55-d92b-4ffa-b03b-742c60a91e7c"
      }
    },
    "owner": "williamdevbackend",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cc180b55-d92b-4ffa-b03b-742c60a91e7c"
    },
    "ios": {}
  }
}
