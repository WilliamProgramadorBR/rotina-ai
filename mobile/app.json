{
  "expo": {
    "name": "Rotina AI",
    "slug": "rotina-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "rotinaai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      },
      "package": "com.william.rotinaai",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc180b55-d92b-4ffa-b03b-742c60a91e7c"
      }
    },
    "owner": "williamdevbackend"
  }
}
