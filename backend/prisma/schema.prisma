generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ScheduleCategory {
  HEALTH
  STUDY
  WORKOUT
  WORK
  SLEEP
  WATER
  PERSONAL
  OTHER
}

enum ScheduleSourceType {
  MANUAL
  AI_PROMPT
  MEDICAL_IMAGE
  IMPORTED_TEXT
}

enum ReminderStatus {
  ACTIVE
  PAUSED
  FINISHED
  CANCELED
}

enum ReminderAction {
  DONE
  SNOOZED
  SKIPPED
  MISSED
}

enum AlarmLevel {
  LEVE
  IMPORTANTE
  CRITICO
  ROTINA
}

enum CollaborationRole {
  OWNER
  ADMIN
  MEMBER
}

enum CollaborationInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum AppNotificationType {
  CHAT_MESSAGE
  GROUP_INVITE
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  avatarUrl         String?   @db.Text
  passwordHash      String
  pushToken         String?   @db.VarChar(255)
  acceptedPrivacyAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  schedules                    Schedule[]
  reminderLogs                 ReminderLog[]
  reminderComments             ReminderComment[]
  alarmLogs                    AlarmLog[]
  aiRequests                   AiRequest[]
  passwordResetTokens          PasswordResetToken[]
  ownedGroups                  CollaborationGroup[]    @relation("CollaborationGroupOwner")
  collaborationMemberships     CollaborationMember[]
  sentCollaborationInvites     CollaborationInvite[]   @relation("CollaborationInviteSender")
  receivedCollaborationInvites CollaborationInvite[]   @relation("CollaborationInviteRecipient")
  assignedReminders            Reminder[]              @relation("ReminderAssignee")
  collaborationMessages        CollaborationMessage[]
  collaborationPresences       CollaborationPresence[]
  notificationPreference       NotificationPreference?
  appNotifications             AppNotification[]
}

model NotificationPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  chatNotificationsEnabled Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Schedule {
  id          String             @id @default(cuid())
  userId      String
  groupId     String?
  title       String             @db.Text
  description String?            @db.Text
  notes       String?            @db.Text
  linksJson   String?            @db.Text
  extraInfo   String?            @db.Text
  category    ScheduleCategory   @default(OTHER)
  sourceType  ScheduleSourceType @default(MANUAL)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     CollaborationGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reminders Reminder[]
}

model Reminder {
  id             String         @id @default(cuid())
  scheduleId     String
  assignedUserId String?
  title          String         @db.Text
  description    String?        @db.Text
  notes          String?        @db.Text
  linksJson      String?        @db.Text
  location       String?        @db.Text
  priority       String?
  alarmLevel     AlarmLevel     @default(IMPORTANTE)
  startAt        DateTime
  endAt          DateTime?
  recurrenceRule String?        @db.Text
  timezone       String         @default("America/Sao_Paulo")
  status         ReminderStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  schedule     Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignedUser User?             @relation("ReminderAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  logs         ReminderLog[]
  comments     ReminderComment[]
}

model ReminderLog {
  id         String         @id @default(cuid())
  userId     String
  reminderId String
  action     ReminderAction
  note       String?        @db.Text
  createdAt  DateTime       @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
}

model ReminderComment {
  id         String   @id @default(cuid())
  userId     String
  reminderId String
  message    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlarmLog {
  id         String   @id @default(cuid())
  userId     String
  scheduleId String?
  reminderId String?
  alarmTime  DateTime
  status     String   @default("scheduled")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiRequest {
  id             String   @id @default(cuid())
  userId         String
  inputType      String
  prompt         String?  @db.Text
  imageUrl       String?  @db.Text
  aiResponseJson String?  @db.Text
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CollaborationGroup {
  id          String   @id @default(cuid())
  ownerId     String
  name        String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User                    @relation("CollaborationGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   CollaborationMember[]
  invites   CollaborationInvite[]
  schedules Schedule[]
  messages  CollaborationMessage[]
  presences CollaborationPresence[]
}

model CollaborationMember {
  id       String            @id @default(cuid())
  groupId  String
  userId   String
  role     CollaborationRole @default(MEMBER)
  joinedAt DateTime          @default(now())

  group CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model CollaborationInvite {
  id            String                    @id @default(cuid())
  groupId       String
  email         String
  invitedById   String
  invitedUserId String?
  status        CollaborationInviteStatus @default(PENDING)
  message       String?                   @db.Text
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  acceptedAt    DateTime?

  group       CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy   User               @relation("CollaborationInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser User?              @relation("CollaborationInviteRecipient", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, email])
}

model CollaborationMessage {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

model CollaborationPresence {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group CollaborationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, lastSeenAt])
}

model AppNotification {
  id        String              @id @default(cuid())
  userId    String
  type      AppNotificationType
  title     String              @db.VarChar(255)
  body      String              @db.Text
  data      String?             @db.Text
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
